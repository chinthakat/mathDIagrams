generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Generation {
  id        String   @id @default(uuid())
  title     String
  category  String
  createdAt DateTime @default(now())
  request   String   // JSON string
  payload   String   // JSON string
}

model MockExam {
  id            String  @id
  title         String
  gradeLevel    String?
  questionCount Int     @default(0)
}
